{
  "name": "with-cloudflare-workers",
  "type": "module",
  "scripts": {
    "generate:routes": "ts-api-compiler generate-routes --routes ./src/routes --output ./src/routes.generated.ts",
    "dev": "pnpm generate:routes && wrangler dev",
    "build": "pnpm generate:routes",
    "deploy": "pnpm build && wrangler deploy --minify",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings"
  },
  "dependencies": {
    "hono": "^4.9.10",
    "@ts-api-kit/core": "workspace:*",
    "valibot": "^1.1.0"
  },
  "devDependencies": {
    "@ts-api-kit/compiler": "workspace:*",
    "wrangler": "^4.4.0"
  }
}