# Source-only publish; keep TypeScript sources.
# Exclude tests, fixtures, and dev config that the `files` array in package.json
# already leaves out, so `.npmignore` stays aligned if `files` is ever removed.

# Tests and fixtures
*.test.ts
*.spec.ts
test/
tests/
__tests__/
__fixtures__/

# Dev / build config
tsconfig.json
tsconfig.tsbuildinfo
jsr.json
deno.json
deno.lock
biome.json
.biome.json

# Docs and examples
docs/
examples/

# Git / IDE / OS
.git/
.gitignore
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# Dependencies and build artifacts
node_modules/
dist/
